{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Pool Utilization",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "opencode_scale_allocated_count / opencode_scale_pool_size * 100",
          "legendFormat": "Utilization %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          },
          "unit": "percent",
          "max": 100,
          "min": 0
        }
      }
    },
    {
      "title": "Active Sandboxes",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "opencode_scale_allocated_count",
          "legendFormat": "Allocated"
        }
      ]
    },
    {
      "title": "Queue Depth",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "opencode_scale_wait_queue_length",
          "legendFormat": "Waiting"
        }
      ]
    },
    {
      "title": "Allocation Latency (p95)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(opencode_scale_allocation_latency_bucket[5m]))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "title": "Task Status",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(opencode_scale_task_status_total[5m])",
          "legendFormat": "{{ status }}"
        }
      ]
    },
    {
      "title": "Task Duration (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(opencode_scale_task_duration_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(opencode_scale_task_duration_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(opencode_scale_task_duration_bucket[5m]))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "title": "LLM Tokens (rate/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "rate(opencode_scale_llm_tokens_total[1m]) * 60",
          "legendFormat": "tokens/min"
        }
      ]
    },
    {
      "title": "Pool Size Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "opencode_scale_pool_size",
          "legendFormat": "Total"
        },
        {
          "expr": "opencode_scale_allocated_count",
          "legendFormat": "Allocated"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["opencode-scale"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "OpenCode Scale Overview",
  "uid": "opencode-scale-overview"
}
